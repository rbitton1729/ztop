# Maintainer: Raphael Bitton <raphael@skylantix.com>
pkgname=zfstop
pkgver=0.0.0
pkgrel=1
pkgdesc="A terminal dashboard for ZFS, in the spirit of htop"
arch=('x86_64')
url="https://git.skylantix.com/rbitton/zfstop"
license=('MIT')
depends=()
keywords=('zfs' 'zfstop')
source=("zfstop-${pkgver}-linux-amd64::https://git.skylantix.com/api/v4/projects/rbitton%2Fzfstop/packages/generic/zfstop/${pkgver}/zfstop-linux-amd64"
        "LICENCE-${pkgver}::https://git.skylantix.com/rbitton/zfstop/-/raw/v${pkgver}/LICENCE")
sha256sums=('SKIP' 'SKIP')

package() {
    install -Dm755 "zfstop-${pkgver}-linux-amd64" "$pkgdir/usr/bin/zfstop"
    install -Dm644 "LICENCE-${pkgver}" "$pkgdir/usr/share/licenses/$pkgname/LICENCE"
}
